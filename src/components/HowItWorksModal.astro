---
---

<div class="modal-backdrop" id="howModal" role="dialog" aria-modal="true" aria-labelledby="howTitle">
  <div class="modal" role="document">
    <div class="modal-head">
      <h3 id="howTitle">How InvoicePass works</h3>
      <button class="modal-close" id="modalClose" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="modal-step">
        <div class="modal-step-num">1</div>
        <div>
          <div class="modal-step-title">Pick your inbox name</div>
          <div class="modal-step-desc">Choose a short handle. It becomes your unique address — for example <span class="mono">silva@invoicepass.app</span>.</div>
        </div>
      </div>
      <div class="modal-step">
        <div class="modal-step-num">2</div>
        <div>
          <div class="modal-step-title">Send or forward invoices</div>
          <div class="modal-step-desc">Vendors email PDFs to that address. Or forward existing emails — we parse the attachment, not the message.</div>
        </div>
      </div>
      <div class="modal-step">
        <div class="modal-step-num">3</div>
        <div>
          <div class="modal-step-title">They land in your portal</div>
          <div class="modal-step-desc">Signed, deduped, delivered exactly once. Review in the portal or push to your stack via webhook.</div>
        </div>
      </div>
    </div>
    <div class="modal-foot">No setup. No SDK. Works with any vendor that can send a PDF.</div>
  </div>
</div>
