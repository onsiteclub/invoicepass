---
import ClaimForm from './ClaimForm.astro';
import ClaimSuccessCard from './ClaimSuccessCard.astro';
import InboxMock from './InboxMock.astro';
---

<section class="hero" id="claim-hero">
  <div class="container">
    <div class="hero-grid">

      <div>
        <div class="hero-eyebrow eyebrow"><span class="blue-dot"></span>For foremen, contractors, and crews</div>

        <h1><span class="primary-blue">Every invoice.</span> <span class="accent">In one inbox</span></h1>

        <p class="hero-sub">
          Forward invoices from anywhere. Sorted by person. Settle at month end.
        </p>

        <ClaimForm formId="claimFormOp" inputId="handleInputOp" howLinkId="howLinkOp">
          <div class="claim-note" slot="note">
            <span class="check">✓</span>
            Free up to 10 users · No credit card · One inbox per operator
          </div>
        </ClaimForm>

        <ClaimSuccessCard cardId="claimSuccessOp" handleId="handleResultOp" emailId="handleEmailOp" />
      </div>

      <InboxMock />

    </div>
  </div>
</section>
