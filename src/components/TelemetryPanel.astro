---
---

<div class="telemetry">
  <div class="tel-header">
    <div class="tel-header-left">
      <span class="live-dot"></span>
      LIVE · global ingress
    </div>
    <div class="tel-window-controls">
      <span></span><span></span><span></span>
    </div>
  </div>
  <div class="tel-stream" id="telStream">
    <!-- populated by JS -->
  </div>
  <div class="tel-footer">
    <div class="tel-stat">
      <div class="tel-stat-label">Today</div>
      <div class="tel-stat-val" id="statToday">14,827</div>
    </div>
    <div class="tel-stat">
      <div class="tel-stat-label">P95 latency</div>
      <div class="tel-stat-val" id="statLatency">142<span class="unit">ms</span></div>
    </div>
    <div class="tel-stat">
      <div class="tel-stat-label">Dedup rate</div>
      <div class="tel-stat-val" id="statDedup">3.4<span class="unit">%</span></div>
    </div>
  </div>
</div>
