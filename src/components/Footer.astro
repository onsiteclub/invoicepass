---
import Logo from './Logo.astro';
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo" style="font-size: 14.5px;">
          <Logo variant="compact" />
          <span class="logo-text">Invoice<span class="logo-flow">Pass</span></span>
        </div>
        <p class="footer-brand-text">The working ledger for the people who build.</p>
      </div>

      <div class="footer-col">
        <h4>Product</h4>
        <ul>
          <li><a href="/#how">How it works</a></li>
          <li><a href="/#pricing">Pricing</a></li>
          <li><a href="/security">Security</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>For teams</h4>
        <ul>
          <li><a href="#" data-stub>For foremen</a></li>
          <li><a href="#" data-stub>For contractors</a></li>
          <li><a href="#" data-stub>For cleaning crews</a></li>
          <li><a href="#" data-stub>For drivers</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Developers</h4>
        <ul>
          <li><a href="/#developers">Get in touch</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
          <li><a href="/data-export">Data export</a></li>
          <li><a href="/security">Security</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© 2026 InvoicePass · v1.4.2 · ca-central-1</span>
      <div class="footer-bottom-right">
        <span class="status-pill" style="background: transparent;">
          <span class="dot"></span>
          operational
        </span>
      </div>
    </div>
  </div>
</footer>
