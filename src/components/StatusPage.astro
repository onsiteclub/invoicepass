---
interface Props {
  variant?: 'dev' | 'op';
}

const { variant = 'dev' } = Astro.props;
const isDev = variant === 'dev';
---

<section class="spaced" id="status" style="background: var(--surface-2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
  <div class="container">
    <div class="section-head">
      {isDev ? (
        <>
          <span class="eyebrow"><span class="blue-dot"></span>Status</span>
          <h2><span class="primary-blue">Public uptime,</span> <span class="accent">real numbers</span></h2>
          <p>Every service is monitored externally and reported here without filter. Last 90 days shown. Incidents disclosed within 15 minutes.</p>
        </>
      ) : (
        <>
          <span class="eyebrow"><span class="blue-dot"></span>Reliability</span>
          <h2><span class="primary-blue">Up when you need it.</span> <span class="accent">Always</span></h2>
          <p>We watch this 24/7. So you don't have to.</p>
        </>
      )}
    </div>

    <div class="status-card">
      <div class="status-card-head">
        <h3>Service health</h3>
        <span class="status-overall"><span class="dot"></span>All systems operational</span>
      </div>

      <div class="status-row">
        <div class="status-svc">
          <div class="status-svc-name">Inbound (SMTP)</div>
          <div class="status-svc-desc">smtp.invoicepass.app:587</div>
        </div>
        <div class="uptime-bar" data-pattern="all-good"></div>
        <div class="latency">p95 · 142 ms</div>
        <div class="status-state">healthy</div>
      </div>

      <div class="status-row">
        <div class="status-svc">
          <div class="status-svc-name">Parser</div>
          <div class="status-svc-desc">PDF extraction service</div>
        </div>
        <div class="uptime-bar" data-pattern="one-blip"></div>
        <div class="latency">p95 · 218 ms</div>
        <div class="status-state">healthy</div>
      </div>

      <div class="status-row">
        <div class="status-svc">
          <div class="status-svc-name">Storage</div>
          <div class="status-svc-desc">ca-central-1 · encrypted</div>
        </div>
        <div class="uptime-bar" data-pattern="all-good"></div>
        <div class="latency">p95 · 64 ms</div>
        <div class="status-state">healthy</div>
      </div>

      <div class="status-row">
        <div class="status-svc">
          <div class="status-svc-name">Portal</div>
          <div class="status-svc-desc">portal.invoicepass.app</div>
        </div>
        <div class="uptime-bar" data-pattern="all-good"></div>
        <div class="latency">p95 · 89 ms</div>
        <div class="status-state">healthy</div>
      </div>

      <div class="status-row">
        <div class="status-svc">
          <div class="status-svc-name">Webhook delivery</div>
          <div class="status-svc-desc">signed URL push</div>
        </div>
        <div class="uptime-bar" data-pattern="all-good"></div>
        <div class="latency">p95 · 198 ms</div>
        <div class="status-state">healthy</div>
      </div>
    </div>
  </div>
</section>
