# Supabase — same project the onsite-ops portal uses. Both keys are safe
# to expose in the browser bundle: the URL is public by design, and the
# anon key only does what the RLS policies allow (which for the landing
# is: insert into contact_messages, nothing else).
#
# Pull both values from Supabase Studio -> Project Settings -> API.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
