---
import Logo from './Logo.astro';
---

<nav>
  <div class="container nav-row">
    <div class="nav-left">
      <a href="/" class="logo">
        <Logo variant="nav" />
        InvoicePass
      </a>
      <div class="nav-links">
        <a href="#protocol">Protocol</a>
        <a href="#integrate">Integrate</a>
        <a href="#status">Status</a>
        <a href="#" data-stub>Docs</a>
        <a href="#" data-stub>Changelog</a>
      </div>
    </div>
    <div class="nav-right">
      <button class="persona-switch" id="personaSwitch" type="button" title="Switch view">
        <svg class="swap-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>
        <span id="personaLabel">developer view</span>
      </button>
      <span class="status-pill">
        <span class="dot"></span>
        all systems operational
      </span>
      <a href="https://portal.invoicepass.app" class="btn btn-ghost">Sign in</a>
      <a href="#claim" class="btn btn-primary">Get access</a>
    </div>
  </div>
</nav>
