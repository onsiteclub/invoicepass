---
import TelemetryPanel from './TelemetryPanel.astro';
---

<section class="hero">
  <div class="container">
    <div class="hero-grid">

      <div>
        <div class="hero-eyebrow eyebrow"><span class="blue-dot"></span>v1.4 — inbound endpoint</div>

        <h1><span class="primary-blue">The invoice</span> <span class="accent">ingestion layer</span></h1>

        <p class="hero-sub">
          One inbox per operator. SMTP ingress, deterministic deduplication, signed delivery to your stack — so no invoice ever lands in the wrong place, twice, or not at all.
        </p>

        <div class="hero-cta-wrap">
          <button type="button" class="btn-cta-primary" data-dev-signup-open>
            Join the dev preview
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <p class="hero-cta-note mono">
            Free during preview · Manual onboarding · Keys within 48h
          </p>
        </div>

      </div>

      <TelemetryPanel />

    </div>
  </div>
</section>
