---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import HeroOperator from '../components/HeroOperator.astro';
// import WhatItIsIsnt from '../components/WhatItIsIsnt.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import LiveInboxExample from '../components/LiveInboxExample.astro';
import PricingSection from '../components/PricingSection.astro';
// import StatusPage from '../components/StatusPage.astro';
import CTAOperator from '../components/CTAOperator.astro';
import Footer from '../components/Footer.astro';
import HowItWorksModal from '../components/HowItWorksModal.astro';
import Toast from '../components/Toast.astro';
---

<Base
  title="InvoicePass — A working ledger for foremen, contractors, and crews"
  description="Every invoice you get, in one inbox. Sorted by person. See who owes you, who you owe, and settle up at the end of the month. Free for crews up to 10 people."
>
  <Nav variant="op" />
  <HeroOperator />
  {/* <WhatItIsIsnt /> */}
  <HowItWorksSection />
  <LiveInboxExample />
  <PricingSection />
  {/* <StatusPage variant="op" /> */}
  <CTAOperator />
  <Footer variant="op" />
  <HowItWorksModal />
  <Toast />
</Base>
