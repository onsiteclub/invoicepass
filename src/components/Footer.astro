---
import Logo from './Logo.astro';

interface Props {
  variant?: 'dev' | 'op';
}

const { variant = 'dev' } = Astro.props;
const isDev = variant === 'dev';

const brandText = isDev
  ? 'The invoice ingestion layer. Signed, deduped, delivered exactly once.'
  : 'The working ledger for the people who build.';
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="logo" style="font-size: 14.5px;">
          <Logo variant="compact" />
          <span class="logo-text">Invoice<span class="logo-flow">Pass</span></span>
        </div>
        <p class="footer-brand-text">{brandText}</p>
      </div>

      {isDev ? (
        <>
          <div class="footer-col">
            <h4>Product</h4>
            <ul>
              <li><a href="#protocol">Protocol</a></li>
              <li><a href="#integrate">API</a></li>
              <li><a href="#status">Status</a></li>
              <li><a href="#" data-stub>Changelog</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Developers</h4>
            <ul>
              <li><a href="#" data-stub>Documentation</a></li>
              <li><a href="#" data-stub>API reference</a></li>
              <li><a href="#" data-stub>Webhooks</a></li>
              <li><a href="#" data-stub>SDKs</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>For teams</h4>
            <ul>
              <li><a href="/inbox">For foremen</a></li>
              <li><a href="/inbox">For contractors</a></li>
              <li><a href="/inbox#how">How it works</a></li>
              <li><a href="/inbox#pricing">Pricing</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Legal</h4>
            <ul>
              <li><a href="#" data-stub>Privacy</a></li>
              <li><a href="#" data-stub>Terms</a></li>
              <li><a href="#" data-stub>DPA</a></li>
              <li><a href="#" data-stub>Security</a></li>
            </ul>
          </div>
        </>
      ) : (
        <>
          <div class="footer-col">
            <h4>Product</h4>
            <ul>
              <li><a href="#how">How it works</a></li>
              <li><a href="#pricing">Pricing</a></li>
              <li><a href="#" data-stub>Security</a></li>
              <li><a href="#status">Status</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>For teams</h4>
            <ul>
              <li><a href="#" data-stub>For foremen</a></li>
              <li><a href="#" data-stub>For contractors</a></li>
              <li><a href="#" data-stub>For cleaning crews</a></li>
              <li><a href="#" data-stub>For drivers</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Developers</h4>
            <ul>
              <li><a href="/#integrate">API</a></li>
              <li><a href="/" data-stub>Documentation</a></li>
              <li><a href="/#protocol">Protocol</a></li>
              <li><a href="/" data-stub>Changelog</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Legal</h4>
            <ul>
              <li><a href="#" data-stub>Privacy</a></li>
              <li><a href="#" data-stub>Terms</a></li>
              <li><a href="#" data-stub>Data export</a></li>
              <li><a href="#" data-stub>Security</a></li>
            </ul>
          </div>
        </>
      )}
    </div>

    <div class="footer-bottom">
      <span>© 2026 InvoicePass · v1.4.2 · ca-central-1</span>
      <div class="footer-bottom-right">
        <span class="status-pill" style="background: transparent;">
          <span class="dot"></span>
          operational
        </span>
      </div>
    </div>
  </div>
</footer>
